# ── Ports (must be unique across all profiles in this container) ───────────────
HERMES_GATEWAY_PORT=8644
HERMES_DASHBOARD_PORT=9121

# ── Dashboard ──────────────────────────────────────────────────────────────────
HERMES_DASHBOARD=1
# Generate a unique token per profile: openssl rand -base64 32
HERMES_DASHBOARD_SESSION_TOKEN=

# ── Anthropic ──────────────────────────────────────────────────────────────────
# Shared key — same value across all profile .env files
ANTHROPIC_API_KEY=sk-ant-...

# ── Discord ────────────────────────────────────────────────────────────────────
# Create a dedicated Discord Application for this profile at:
# https://discord.com/developers/applications
# Each profile must have its OWN Discord app and bot token — never share.
DISCORD_BOT_TOKEN=

# ── Telegram ───────────────────────────────────────────────────────────────────
# Create a dedicated bot via @BotFather on Telegram.
# Each profile must have its OWN Telegram bot — never share.
TELEGRAM_BOT_TOKEN=