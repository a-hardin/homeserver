# Alpaca trader — runtime secrets. Copy to `.env` in this directory and fill in.
# This file is committed as a template; the real `.env` is gitignored.
# The image contains NO credentials — everything account-specific lives here.

# --- Alpaca (paper account) ---------------------------------------------------
# Create paper-trading keys at https://app.alpaca.markets (Paper account).
APCA_API_KEY_ID=your-alpaca-paper-key-id
APCA_API_SECRET_KEY=your-alpaca-paper-secret-key

# Paper by default. Going live is a DELIBERATE change to this one line, never a
# runtime toggle. Leave as-is unless you truly mean to trade real money.
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# No Discord token here: the trader has NO Discord access. Hermes is the only
# service that talks to Discord, and it drives the trader's control surface
# (status / halt / flatten) over the internal network at http://trader:8080.

# --- Operator dashboard ------------------------------------------------------
# Password for the LAN-only operator dashboard (http://<server-lan-ip>:8090).
# Required to enable the dashboard; without it the daemon refuses to serve the
# account-control UI unauthenticated. The dashboard is where you grant or revoke
# an AI agent's permission to trade.
DASHBOARD_PASSWORD=set-a-strong-password